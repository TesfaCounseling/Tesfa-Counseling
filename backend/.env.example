FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret
# SQLite dev default: local copy off Google Drive to avoid sync lock errors.
# Override with DATABASE_URL for Postgres/production.
LOCAL_DATABASE_PATH=C:/dev/tesfa-counseling/tesfa_counseling.db
DATABASE_CONNECT_TIMEOUT=30
DATABASE_STATEMENT_TIMEOUT_MS=30000
CORS_ORIGINS=http://localhost:3000
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
DAILY_API_KEY=
STRIPE_SECRET_KEY=

# Email (optional — logs to console in dev if SMTP_HOST is empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

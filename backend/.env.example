FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret
# Local dev: leave DATABASE_URL empty to use SQLite at LOCAL_DATABASE_PATH.
# Production (Render): set DATABASE_URL to your Postgres connection string.
DATABASE_URL=
LOCAL_DATABASE_PATH=C:/dev/tesfa-counseling/tesfa_counseling.db
DATABASE_CONNECT_TIMEOUT=30
DATABASE_STATEMENT_TIMEOUT_MS=30000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
DAILY_API_KEY=
STRIPE_SECRET_KEY=

# Email (optional — logs to console in dev if SMTP_HOST is empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
